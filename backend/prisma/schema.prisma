generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Skill {
  id        Int    @id @default(autoincrement())
  name      String @unique
  level     String
  category  String? // "Frontend", "Backend", "AI/ML", etc
  proficiency Int? // 1-5 scale or percentage
}

model Project {
  id               Int    @id @default(autoincrement())
  title            String @unique
  description      String
  long_description String? // for future detail views
  tech_stack       String
  github_url       String?
  live_url         String?
  category         String? // "Web", "AI/ML", "Hackathon", etc
  featured         Boolean @default(false)
  date             DateTime? // completion date
}


model About {
  id      Int    @id @default(autoincrement())
  content String
}

model Contact {
  id      Int    @id @default(autoincrement())
  name    String
  email   String
  message String
  createdAt DateTime @default(now())
}
